# Copiar para .env e preencher os valores reais
# O arquivo .env nunca deve ser commitado no git

# ─── Usuário administrador ────────────────────────────────────────────────────
ADMIN_USER=apli.adm
ADMIN_PUBKEY="ssh-ed25519 AAAA... user@host"
# true = adiciona entrada NOPASSWD em /etc/sudoers.d/
ADMIN_NOPASSWD=false

# ─── Rede de gerência (restringe SSH) ────────────────────────────────────────
# Deixar vazio para permitir SSH de qualquer IP (não recomendado em produção)
MGMT_NETWORK=10.50.0.0/24

# ─── Endereçamento DMZ (target migrate-network) ──────────────────────────────
DMZ_INTERFACE=ens3
DMZ_IP=10.10.50.X
DMZ_PREFIX=24
DMZ_GATEWAY=10.10.50.1
DMZ_DNS_1=8.8.8.8
DMZ_DNS_2=1.1.1.1

# ─── NGINX ───────────────────────────────────────────────────────────────────
CLIENT_MAX_BODY_SIZE=10m
# off = não verifica certificado do backend (lab); on = verifica (produção)
PROXY_SSL_VERIFY=off

# ─── Let's Encrypt ───────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=infra@aplidigital.com.br
# certbot ou dns-01 (requer plugin DNS específico)
CERTBOT_METHOD=certbot

# ─── Backup remoto (opcional) ────────────────────────────────────────────────
# Deixar vazio para desabilitar cópia remota
BACKUP_REMOTE_HOST=
BACKUP_REMOTE_PATH=/backups/apldmz01
BACKUP_REMOTE_USER=backup
